# ==================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==================================
# Copy this file to .env in your production server and fill in the values

# ----------------------------------
# Docker Registry Configuration
# ----------------------------------
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your-github-username
IMAGE_TAG=latest

# ----------------------------------
# Database Configuration  
# ----------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=phone_services
# NOTE: POSTGRES_PORT is managed in docker-compose.prod.yml
# External port: 5439, Internal port: 5432 (don't change this)

# ----------------------------------
# Authentication Configuration
# ----------------------------------
# IMPORTANT: Generate a secure random string for production
# Example: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_THIS_TO_SECURE_RANDOM_STRING

# The public URL where your app will be accessible
BETTER_AUTH_URL=http://your-domain.com
NEXT_PUBLIC_BETTER_AUTH_URL=http://your-domain.com

# ----------------------------------
# External API Configuration
# ----------------------------------
# URL to external API if needed
API_EXT_URL=

# ----------------------------------
# Application Configuration
# ----------------------------------
NODE_ENV=production

# ----------------------------------
# NOTES
# ----------------------------------
# 1. Never commit .env to version control
# 2. Keep env.production.example updated with new variables (without values)
# 3. DATABASE_URL is auto-generated from POSTGRES_* variables in docker-compose.prod.yml
# 4. Generate secure passwords using: openssl rand -base64 32
