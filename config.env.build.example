# ============================================
# CONFIGURACIÓN PARA BUILD Y PUSH DE IMAGEN
# ============================================
# Copia este archivo a .env.build y ajusta los valores
# Este archivo se usa EN LOCAL para construir y subir la imagen

# === Docker Registry Configuration ===

# Registry donde se subirá la imagen
# Opciones comunes:
#   - GitHub Container Registry: ghcr.io
#   - Docker Hub: docker.io (o dejar vacío)
#   - Harbor u otro privado: registry.example.com
DOCKER_REGISTRY=ghcr.io

# Usuario o organización en el registry
# Para Docker Hub: tu username de Docker Hub
# Para GitHub: tu username o nombre de organización de GitHub
# nota: Puedes escribir "MiUsuario" y se convertirá a "miusuario"
DOCKER_USERNAME=username

# Nombre de la imagen (usualmente no necesitas cambiar esto)
IMAGE_NAME=phone-services-app

# Tag de la imagen
# Ejemplos:
#   - latest (última versión, desarrollo continuo)
#   - v1.0.0 (versionado semántico)
#   - production (ambiente de producción)
#   - staging (ambiente de staging)
IMAGE_TAG=latest

# ============================================
# VARIABLES DE ENTORNO PARA EL BUILD
# ============================================
# IMPORTANTE: Estas variables se inyectan en el código durante el build
# Deben coincidir con los valores que usarás en producción

# URL base de Better Auth (debe ser la URL pública de tu aplicación)
# Ejemplos:
#   - Producción: https://tu-dominio.com
#   - Staging: https://staging.tu-dominio.com
#   - Desarrollo local: http://localhost:5023
NEXT_PUBLIC_BETTER_AUTH_URL=https://tu-dominio.com

# ============================================
# INSTRUCCIONES
# ============================================
# 
# 1. Copia este archivo:
#    cp config.env.build.example .env.build
# 
# 2. Edita .env.build con tus valores reales
# 
# 3. Autentica tu Docker con el registry:
#    - GitHub: echo $TOKEN | docker login ghcr.io -u USERNAME --password-stdin
#    - Docker Hub: docker login
# 
# 4. Ejecuta el script de build:
#    ./scripts/build-and-push.sh
# 
