# ============================================
# BUILD & PUSH CONFIGURATION
# ============================================
# Copy this file to .env.build and adjust the values.
# Used locally to build and push the Docker image.

# === Docker Registry ===

# Registry to push the image to.
# Common options:
#   - GitHub Container Registry: ghcr.io
#   - Docker Hub: docker.io (or leave empty)
#   - Private registry: registry.example.com
DOCKER_REGISTRY=ghcr.io

# Your username or organization on the registry.
# For Docker Hub: your Docker Hub username
# For GitHub: your GitHub username or organization name
# Note: uppercase letters are automatically lowercased
DOCKER_USERNAME=username

# Image name (usually the project name)
IMAGE_NAME=fast-next-template

# Image tag
# Examples:
#   latest       — rolling latest build
#   v1.0.0       — semantic versioning
#   production   — production environment
IMAGE_TAG=latest

# ============================================
# BUILD-TIME ENVIRONMENT VARIABLES
# ============================================
# These variables are injected into the Next.js build.
# They must match the values used in production.

# Public base URL of your application (used by Better Auth)
# Examples:
#   Production: https://your-domain.com
#   Staging:    https://staging.your-domain.com
#   Local:      http://localhost:5023
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-domain.com

# ============================================
# USAGE
# ============================================
#
# 1. Copy this file:
#    cp config.env.build.example .env.build
#
# 2. Edit .env.build with your real values
#
# 3. Authenticate with your registry:
#    GitHub:     echo $TOKEN | docker login ghcr.io -u USERNAME --password-stdin
#    Docker Hub: docker login
#
# 4. Run the build script:
#    ./scripts/build-and-push.sh
#
