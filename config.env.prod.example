# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env on your production server.
# Used by docker-compose.prod.yml.

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=fast_next_template
POSTGRES_PORT=5432

# === Docker Registry ===
# Must match the values used during the image build

# Registry the image will be pulled from
DOCKER_REGISTRY=ghcr.io

# Username or organization (must match the one used to push the image, lowercased)
DOCKER_USERNAME=username

# Image tag to pull and run
IMAGE_TAG=latest

# === Application ===

# Base URL of your application (no trailing slash)
BETTER_AUTH_URL=https://your-domain.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://your-domain.com

# Auth secret for signing cookies and tokens
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-secure-random-string

# Database URL (constructed from POSTGRES_* vars by docker-compose.prod.yml)
# DATABASE_URL is set automatically — no need to set it here unless overriding

# Additional API keys (add as needed)
# API_KEY=your-api-key
# API_SECRET=your-api-secret

# ============================================
# SECURITY REMINDERS
# ============================================
# ⚠  Never commit this file with real values
# ⚠  Use strong passwords for POSTGRES_PASSWORD
# ⚠  Use different passwords for dev and prod
# ⚠  Consider a secrets manager for production

# ============================================
# USAGE
# ============================================
#
# 1. On your server, copy this file:
#    cp config.env.prod.example .env
#
# 2. Edit .env with your real values:
#    nano .env
#
# 3. Authenticate with Docker (if registry is private):
#    docker login ghcr.io
#
# 4. Pull the image:
#    docker-compose -f docker-compose.prod.yml pull
#
# 5. Start services:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 6. Check status:
#    docker-compose -f docker-compose.prod.yml ps
#    docker-compose -f docker-compose.prod.yml logs -f app
#
