# ============================================
# CONFIGURACIÓN PARA PRODUCCIÓN
# ============================================
# Copia este archivo a .env en el SERVIDOR DE PRODUCCIÓN
# Este archivo define las variables para docker-compose.prod.yml

# === PostgreSQL Database Configuration ===

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTE_PASSWORD_POR_UNO_SEGURO
POSTGRES_DB=phone_services
POSTGRES_PORT=5432

# === Docker Registry Configuration ===
# IMPORTANTE: Estos valores deben coincidir con los de .env.build (local)

# Registry desde donde se descargará la imagen
DOCKER_REGISTRY=ghcr.io

# Usuario o organización (debe ser el mismo que usaste en el build)
# IMPORTANTE: Debe coincidir exactamente con el usado en .env.build (normalizado a minúsculas)
DOCKER_USERNAME=username

# Tag de la imagen que se descargará
# IMPORTANTE: Cambia esto para actualizar a una versión específica
IMAGE_TAG=latest

# === Application Environment Variables ===
# Agrega aquí las variables de entorno que tu aplicación Next.js necesite

# === Better Auth Configuration ===
# URL base de tu aplicación (sin trailing slash)
BETTER_AUTH_URL=https://tu-dominio.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://tu-dominio.com

# Secret para firmar cookies y tokens (genera uno seguro)
# Puedes generar uno con: openssl rand -base64 32
BETTER_AUTH_SECRET=genera-un-string-aleatorio-largo-y-seguro-aqui

# === Database URL ===
# Ya está configurado automáticamente desde las variables POSTGRES_*
# DATABASE_URL se construye automáticamente en docker-compose.prod.yml

# Ejemplo: Variables de API
# API_KEY=tu-api-key-aqui
# API_SECRET=tu-api-secret-aqui

# ============================================
# SEGURIDAD
# ============================================
# ⚠️  NUNCA commites este archivo con valores reales
# ⚠️  Usa contraseñas fuertes para POSTGRES_PASSWORD
# ⚠️  Diferentes passwords para desarrollo y producción
# ⚠️  Considera usar un gestor de secretos en producción
# 
# ============================================
# INSTRUCCIONES DE USO
# ============================================
# 
# 1. En el servidor de producción, copia este archivo:
#    cp config.env.prod.example .env
# 
# 2. Edita .env con tus valores reales:
#    nano .env
# 
# 3. Autentica Docker (si el registry es privado):
#    docker login ghcr.io
# 
# 4. Descarga la imagen:
#    docker-compose -f docker-compose.prod.yml pull
# 
# 5. Inicia los servicios:
#    docker-compose -f docker-compose.prod.yml up -d
# 
# 6. Verifica el estado:
#    docker-compose -f docker-compose.prod.yml ps
#    docker-compose -f docker-compose.prod.yml logs -f app
# 
